{
  "name": "@cyh/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "dev": "tsx watch src/local.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1002.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@cyh/shared": "workspace:*",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/sensible": "^6.0.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.2.0",
    "ical-generator": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^3.1.0",
    "node-ical": "^0.19.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
