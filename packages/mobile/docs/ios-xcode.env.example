# Copy to ios/.xcode.env after `expo prebuild` (Expo merges with generated file — or append these lines).
# Used when running Xcode script phases (Pods, Expo config).

export NODE_BINARY=$(command -v node)

# Node 24+: Expo config scripts load packages from node_modules; disable TS strip there.
export NODE_OPTIONS="${NODE_OPTIONS:-} --no-experimental-strip-types"
