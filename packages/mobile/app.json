{
  "expo": {
    "name": "Wyoming Events Calendar",
    "extra": {
      "privacyPolicyUrl": "https://casperevents.org/privacy",
      "router": {},
      "eas": {
        "projectId": "0a81e13a-81bb-45d4-a3cc-24a819dea3b9"
      }
    },
    "slug": "wyoming-events-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wyomingevents",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f9fafb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.casperyouthhub.wyomingevents",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.casperyouthhub.wyomingevents",
      "adaptiveIcon": {
        "backgroundColor": "#4A7C3F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-image",
      "./plugins/withMacCatalyst.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
