# Copy to .env and fill in values. Used by CDK deploy for Lambda env vars.
# Get these from Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.casperevents.org/v1/auth/google/callback
